<Application x:Class="GroupyV.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="Views/LoginWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="MainBgColor" Color="#0F111A"/>
            <SolidColorBrush x:Key="SidebarColor" Color="#1A1C2E"/>
            <SolidColorBrush x:Key="AccentColor" Color="#6C5DD3"/>
            <SolidColorBrush x:Key="GlassBorder" Color="#34374C"/>
            <SolidColorBrush x:Key="NavTextInactive" Color="#808191"/>
            <SolidColorBrush x:Key="NavHoverBg" Color="#2D304D"/>
            <SolidColorBrush x:Key="CardBgColor" Color="#1A1C2E"/>
            <SolidColorBrush x:Key="CardBgDarkerColor" Color="#151723"/>
            <SolidColorBrush x:Key="CardHoverColor" Color="#1E2033"/>
            <SolidColorBrush x:Key="BorderSubtleColor" Color="#2D304D"/>
            <SolidColorBrush x:Key="InputBorderColor" Color="#3F4259"/>
            <SolidColorBrush x:Key="TextPrimaryColor" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextSecondaryColor" Color="#808191"/>
            <SolidColorBrush x:Key="FooterBgColor" Color="#252836"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>