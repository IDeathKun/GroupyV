<UserControl x:Class="GroupyV.Views.StockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:GroupyV.Helpers"
             xmlns:converters="clr-namespace:GroupyV.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <helpers:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis" />
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>
    </UserControl.Resources>

    <!-- DIALOG MOUVEMENT STOCK -->
    <materialDesign:DialogHost IsOpen="{Binding IsDialogOpen}" DialogTheme="Dark" OverlayBackground="#CC0F111A">
        <materialDesign:DialogHost.DialogContent>
            <Border Background="{DynamicResource CardBgColor}" CornerRadius="20" Width="480" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.6" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Header -->
                    <Border CornerRadius="20,20,0,0" Padding="28,20">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource CardBgDarkerColor}"/>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="48" Height="48" CornerRadius="14" Margin="0,0,16,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#45E3B8" Opacity="0.15"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEntreeMode}" Value="False">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#FF9F43" Opacity="0.15"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <materialDesign:PackIcon Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Setter Property="Kind" Value="PackageVariantClosedPlus"/>
                                            <Setter Property="Foreground" Value="#45E3B8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEntreeMode}" Value="False">
                                                    <Setter Property="Kind" Value="PackageVariantClosedMinus"/>
                                                    <Setter Property="Foreground" Value="#FF9F43"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Foreground="{DynamicResource TextPrimaryColor}" FontSize="17" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Entrée de stock"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEntreeMode}" Value="False">
                                                    <Setter Property="Text" Value="Sortie de stock"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding SelectedStock.NomProduit}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Formulaire -->
                    <StackPanel Margin="28,20,28,24">
                        <!-- Stock actuel -->
                        <Border Background="{DynamicResource CardBgDarkerColor}" CornerRadius="10" Padding="14,10" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Physique" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedStock.StockPhysique}" Foreground="{DynamicResource TextPrimaryColor}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Réservé" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedStock.StockReserve}" Foreground="#FF9F43" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Disponible" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedStock.StockDisponible}" Foreground="#45E3B8" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Quantité -->
                        <TextBlock Text="Quantité" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Bouton - -->
                            <Button Grid.Column="0" Width="46" Height="46" Click="QuantityMinus_Click"
                                    Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                    materialDesign:ButtonAssist.CornerRadius="10,0,0,10"
                                    Padding="0" Background="{DynamicResource BorderSubtleColor}" BorderThickness="0">
                                <materialDesign:PackIcon Kind="Minus" Width="20" Height="20" Foreground="{DynamicResource TextPrimaryColor}"/>
                            </Button>

                            <!-- Champ numérique -->
                            <TextBox Grid.Column="1" x:Name="QuantityTextBox"
                                     Text="{Binding DialogQuantite, UpdateSourceTrigger=PropertyChanged}"
                                     PreviewTextInput="QuantityTextBox_PreviewTextInput"
                                     DataObject.Pasting="QuantityTextBox_Pasting"
                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                     BorderThickness="0,1,0,1" BorderBrush="{DynamicResource InputBorderColor}"
                                     Background="{DynamicResource CardBgDarkerColor}" Foreground="{DynamicResource TextPrimaryColor}"
                                     FontSize="18" FontWeight="Bold"
                                     TextAlignment="Center" Height="46"
                                     VerticalContentAlignment="Center"
                                     InputScope="Number"/>

                            <!-- Bouton + -->
                            <Button Grid.Column="2" Width="46" Height="46" Click="QuantityPlus_Click"
                                    Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                    materialDesign:ButtonAssist.CornerRadius="0,10,10,0"
                                    Padding="0" Background="{DynamicResource BorderSubtleColor}" BorderThickness="0">
                                <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" Foreground="{DynamicResource TextPrimaryColor}"/>
                            </Button>
                        </Grid>

                        <!-- Raccourcis quantité -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Button Content="+1" Tag="1" Click="QuickQuantity_Click" Width="48" Height="28" FontSize="11" Foreground="{DynamicResource TextSecondaryColor}" Margin="3,0"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="{DynamicResource InputBorderColor}" materialDesign:ButtonAssist.CornerRadius="8" Padding="0"/>
                            <Button Content="+5" Tag="5" Click="QuickQuantity_Click" Width="48" Height="28" FontSize="11" Foreground="{DynamicResource TextSecondaryColor}" Margin="3,0"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="{DynamicResource InputBorderColor}" materialDesign:ButtonAssist.CornerRadius="8" Padding="0"/>
                            <Button Content="+10" Tag="10" Click="QuickQuantity_Click" Width="48" Height="28" FontSize="11" Foreground="{DynamicResource TextSecondaryColor}" Margin="3,0"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="{DynamicResource InputBorderColor}" materialDesign:ButtonAssist.CornerRadius="8" Padding="0"/>
                            <Button Content="+50" Tag="50" Click="QuickQuantity_Click" Width="48" Height="28" FontSize="11" Foreground="{DynamicResource TextSecondaryColor}" Margin="3,0"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="{DynamicResource InputBorderColor}" materialDesign:ButtonAssist.CornerRadius="8" Padding="0"/>
                            <Button Content="+100" Tag="100" Click="QuickQuantity_Click" Width="56" Height="28" FontSize="11" Foreground="{DynamicResource TextSecondaryColor}" Margin="3,0"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="{DynamicResource InputBorderColor}" materialDesign:ButtonAssist.CornerRadius="8" Padding="0"/>
                        </StackPanel>

                        <!-- Motif -->
                        <TextBox Text="{Binding DialogMotif, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Motif" materialDesign:HintAssist.Foreground="{DynamicResource TextSecondaryColor}"
                                 materialDesign:HintAssist.IsFloating="True"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextPrimaryColor}"
                                 MinHeight="56" VerticalContentAlignment="Center" Margin="0,0,0,12"/>

                        <!-- Détail -->
                        <TextBox Text="{Binding DialogMotifDetaille, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Détails (optionnel)" materialDesign:HintAssist.Foreground="{DynamicResource TextSecondaryColor}"
                                 materialDesign:HintAssist.IsFloating="True"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextPrimaryColor}"
                                 MinHeight="90" TextWrapping="Wrap"
                                 AcceptsReturn="True" VerticalContentAlignment="Top" Padding="12,14,12,8" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding DialogPrixAchat, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Prix d'achat"
                                     materialDesign:HintAssist.IsFloating="True"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextPrimaryColor}"
                                     MinHeight="56" VerticalContentAlignment="Center"/>
                            <TextBox Grid.Column="2" Text="{Binding DialogEmplacement, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Emplacement"
                                     materialDesign:HintAssist.IsFloating="True"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextPrimaryColor}"
                                     MinHeight="56" VerticalContentAlignment="Center"/>
                        </Grid>

                        <!-- Boutons -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Annuler" Command="{Binding CloseDialogCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextSecondaryColor}" Height="44" materialDesign:ButtonAssist.CornerRadius="10"/>
                            <Button Grid.Column="2" Command="{Binding ConfirmMouvementCommand}" Foreground="White" FontWeight="Bold" Height="44" materialDesign:ButtonAssist.CornerRadius="10">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatMidBgButton}">
                                        <Setter Property="Content" Value="AJOUTER AU STOCK"/>
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#45E3B8"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEntreeMode}" Value="False">
                                                <Setter Property="Content" Value="RETIRER DU STOCK"/>
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#FF9F43"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </materialDesign:DialogHost.DialogContent>

        <ScrollViewer VerticalScrollBarVisibility="Hidden">
            <Grid Margin="30,20,30,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 1. HEADER -->
                <Grid Grid.Row="0" Margin="0,0,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Gestion des stocks" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryColor}"/>
                        <TextBlock Text="Gérez vos inventaires, suivez les mouvements et anticipez les ruptures." Foreground="{DynamicResource TextSecondaryColor}" FontSize="12" Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Command="{Binding ImportCsvCommand}" Style="{StaticResource MaterialDesignOutlinedButton}"
                                BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextSecondaryColor}" Height="36" Margin="0,0,8,0"
                                materialDesign:ButtonAssist.CornerRadius="10" Padding="14,0" ToolTip="Importer un fichier CSV exporté depuis GroupyV">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileImportOutline" Width="16" Height="16" Margin="0,0,6,0"/>
                                <TextBlock Text="Importer" FontSize="11"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ExportCsvCommand}" Style="{StaticResource MaterialDesignOutlinedButton}"
                                BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextSecondaryColor}" Height="36" Margin="0,0,8,0"
                                materialDesign:ButtonAssist.CornerRadius="10" Padding="14,0" ToolTip="Exporter l'inventaire complet en CSV (compatible Excel)">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileExportOutline" Width="16" Height="16" Margin="0,0,6,0"/>
                                <TextBlock Text="Exporter" FontSize="11"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding RefreshCommand}" Style="{StaticResource MaterialDesignOutlinedButton}"
                                BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextSecondaryColor}" Height="36" materialDesign:ButtonAssist.CornerRadius="10" Padding="14,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,6,0"/>
                                <TextBlock Text="Actualiser" FontSize="11"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- 2. KPI -->
                <Grid Grid.Row="1" Margin="0,0,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource CardBgColor}" CornerRadius="14" Padding="18,14" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,12,0">
                                <Border.Background><SolidColorBrush Color="#6C5DD3" Opacity="0.2"/></Border.Background>
                                <materialDesign:PackIcon Kind="PackageVariantClosed" Width="20" Height="20" Foreground="#6C5DD3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding TotalProduits}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="20" FontWeight="Bold"/>
                                <TextBlock Text="Produits" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{DynamicResource CardBgColor}" CornerRadius="14" Padding="18,14" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,12,0">
                                <Border.Background><SolidColorBrush Color="#45E3B8" Opacity="0.2"/></Border.Background>
                                <materialDesign:PackIcon Kind="Warehouse" Width="20" Height="20" Foreground="#45E3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding TotalUnites}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="20" FontWeight="Bold"/>
                                <TextBlock Text="Unités totales" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Background="{DynamicResource CardBgColor}" CornerRadius="14" Padding="18,14" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,12,0">
                                <Border.Background><SolidColorBrush Color="#FF5B5B" Opacity="0.2"/></Border.Background>
                                <materialDesign:PackIcon Kind="AlertCircleOutline" Width="20" Height="20" Foreground="#FF5B5B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding AlertesCount}" Foreground="#FF5B5B" FontSize="20" FontWeight="Bold"/>
                                <TextBlock Text="En alerte" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="6" Background="{DynamicResource CardBgColor}" CornerRadius="14" Padding="18,14" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,12,0">
                                <Border.Background><SolidColorBrush Color="#FF9F43" Opacity="0.2"/></Border.Background>
                                <materialDesign:PackIcon Kind="SwapHorizontal" Width="20" Height="20" Foreground="#FF9F43" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding MouvementsJour}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="20" FontWeight="Bold"/>
                                <TextBlock Text="Mouvements (auj.)" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 3. BARRE DE RECHERCHE + FILTRES -->
                <Grid Grid.Row="2" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Barre de recherche avec bouton effacer et compteur -->
                    <Border Background="{DynamicResource CardBgColor}" CornerRadius="12" Padding="14,0"
                            BorderThickness="1.5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleColor}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSearchText}" Value="True">
                                        <Setter Property="BorderBrush" Value="#6C5DD3"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icône loupe (change couleur si recherche active) -->
                            <materialDesign:PackIcon Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Setter Property="Kind" Value="Magnify"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSearchText}" Value="True">
                                                <Setter Property="Foreground" Value="#6C5DD3"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>

                            <!-- Champ de saisie -->
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Rechercher par nom, catégorie, emplacement…"
                                     materialDesign:HintAssist.Foreground="{DynamicResource TextSecondaryColor}"
                                     materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                     BorderThickness="0" Background="Transparent"
                                     Foreground="{DynamicResource TextPrimaryColor}"
                                     Height="42" VerticalContentAlignment="Center" FontSize="13"/>

                            <!-- Compteur de résultats (visible uniquement si recherche active) -->
                            <Border Grid.Column="2" CornerRadius="8" Padding="8,3" Margin="6,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding HasSearchText, Converter={StaticResource BoolToVis}}">
                                <Border.Background>
                                    <SolidColorBrush Color="#6C5DD3" Opacity="0.15"/>
                                </Border.Background>
                                <TextBlock Text="{Binding StocksList.Count, StringFormat='{}{0} résultat(s)'}"
                                           Foreground="#6C5DD3" FontSize="10" FontWeight="Bold"/>
                            </Border>

                            <!-- Bouton effacer (visible uniquement si recherche active) -->
                            <Button Grid.Column="3"
                                    Command="{Binding ClearSearchCommand}"
                                    Style="{StaticResource MaterialDesignIconForegroundButton}"
                                    Width="32" Height="32" Padding="0" Margin="0,0,4,0"
                                    VerticalAlignment="Center" ToolTip="Effacer la recherche"
                                    Visibility="{Binding HasSearchText, Converter={StaticResource BoolToVis}}">
                                <materialDesign:PackIcon Kind="CloseCircle" Width="16" Height="16" Foreground="{DynamicResource TextSecondaryColor}"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Filtres pill avec compteurs et état actif -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">

                        <!-- Tous -->
                        <Button Command="{Binding SetFilterCommand}" CommandParameter="Tous"
                                Height="42" Margin="0,0,6,0" Padding="14,0"
                                materialDesign:ButtonAssist.CornerRadius="12">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                    <Setter Property="BorderBrush" Value="{DynamicResource InputBorderColor}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedFilter}" Value="Tous">
                                            <Setter Property="BorderBrush" Value="#6C5DD3"/>
                                            <Setter Property="Foreground" Value="#6C5DD3"/>
                                            <Setter Property="Background">
                                                <Setter.Value><SolidColorBrush Color="#6C5DD3" Opacity="0.1"/></Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FormatListBulleted" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Tous" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Border CornerRadius="8" Padding="6,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"><Setter.Value><SolidColorBrush Color="#6C5DD3" Opacity="0.15"/></Setter.Value></Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedFilter}" Value="Tous">
                                                    <Setter Property="Background"><Setter.Value><SolidColorBrush Color="#6C5DD3" Opacity="0.25"/></Setter.Value></Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding CountTous}" FontSize="10" FontWeight="Bold" Foreground="#6C5DD3"/>
                                </Border>
                            </StackPanel>
                        </Button>

                        <!-- En alerte -->
                        <Button Command="{Binding SetFilterCommand}" CommandParameter="En alerte"
                                Height="42" Margin="0,0,6,0" Padding="14,0"
                                materialDesign:ButtonAssist.CornerRadius="12">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                    <Setter Property="BorderBrush" Value="{DynamicResource InputBorderColor}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedFilter}" Value="En alerte">
                                            <Setter Property="BorderBrush" Value="#FF5B5B"/>
                                            <Setter Property="Foreground" Value="#FF5B5B"/>
                                            <Setter Property="Background">
                                                <Setter.Value><SolidColorBrush Color="#FF5B5B" Opacity="0.1"/></Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircleOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="En alerte" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Border CornerRadius="8" Padding="6,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"><Setter.Value><SolidColorBrush Color="#FF5B5B" Opacity="0.15"/></Setter.Value></Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedFilter}" Value="En alerte">
                                                    <Setter Property="Background"><Setter.Value><SolidColorBrush Color="#FF5B5B" Opacity="0.3"/></Setter.Value></Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding CountAlertes}" FontSize="10" FontWeight="Bold" Foreground="#FF5B5B"/>
                                </Border>
                            </StackPanel>
                        </Button>

                        <!-- Stock OK -->
                        <Button Command="{Binding SetFilterCommand}" CommandParameter="Stock OK"
                                Height="42" Padding="14,0"
                                materialDesign:ButtonAssist.CornerRadius="12">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                    <Setter Property="BorderBrush" Value="{DynamicResource InputBorderColor}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedFilter}" Value="Stock OK">
                                            <Setter Property="BorderBrush" Value="#45E3B8"/>
                                            <Setter Property="Foreground" Value="#45E3B8"/>
                                            <Setter Property="Background">
                                                <Setter.Value><SolidColorBrush Color="#45E3B8" Opacity="0.1"/></Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CheckCircleOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Stock OK" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Border CornerRadius="8" Padding="6,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"><Setter.Value><SolidColorBrush Color="#45E3B8" Opacity="0.15"/></Setter.Value></Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedFilter}" Value="Stock OK">
                                                    <Setter Property="Background"><Setter.Value><SolidColorBrush Color="#45E3B8" Opacity="0.3"/></Setter.Value></Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding CountOk}" FontSize="10" FontWeight="Bold" Foreground="#45E3B8"/>
                                </Border>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Grid>

                <!-- 4. TABLEAU DES STOCKS -->
                <Border Grid.Row="3" Background="{DynamicResource CardBgColor}" CornerRadius="16" Margin="0,0,0,18" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Titre -->
                        <Border BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="0,0,0,1" Padding="22,16">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Warehouse" Width="18" Height="18" Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Inventaire" Foreground="{DynamicResource TextPrimaryColor}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Border Background="{DynamicResource BorderSubtleColor}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StocksList.Count, StringFormat='{}{0} produit(s)'}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- En-tête colonnes (cliquables pour tri) -->
                        <Grid Grid.Row="1" Margin="22,6,22,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Command="{Binding SortCommand}" CommandParameter="NomProduit"
                                    Style="{StaticResource MaterialDesignFlatButton}" Padding="0" Height="24" HorizontalAlignment="Left"
                                    Foreground="{DynamicResource TextSecondaryColor}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="PRODUIT" FontSize="9" FontWeight="Bold"/>
                                    <materialDesign:PackIcon Width="10" Height="10" Margin="3,0,0,0" VerticalAlignment="Center">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Kind" Value="UnfoldMoreHorizontal"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding SortColumn}" Value="NomProduit"/>
                                                            <Condition Binding="{Binding SortAscending}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Kind" Value="ArrowUp"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding SortColumn}" Value="NomProduit"/>
                                                            <Condition Binding="{Binding SortAscending}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Kind" Value="ArrowDown"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1" Command="{Binding SortCommand}" CommandParameter="StockPhysique"
                                    Style="{StaticResource MaterialDesignFlatButton}" Padding="0" Height="24" HorizontalAlignment="Center"
                                    Foreground="{DynamicResource TextSecondaryColor}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="PHYSIQUE" FontSize="9" FontWeight="Bold"/>
                                    <materialDesign:PackIcon Width="10" Height="10" Margin="3,0,0,0" VerticalAlignment="Center">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Kind" Value="UnfoldMoreHorizontal"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding SortColumn}" Value="StockPhysique"/>
                                                            <Condition Binding="{Binding SortAscending}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Kind" Value="ArrowUp"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding SortColumn}" Value="StockPhysique"/>
                                                            <Condition Binding="{Binding SortAscending}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Kind" Value="ArrowDown"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2" Command="{Binding SortCommand}" CommandParameter="StockReserve"
                                    Style="{StaticResource MaterialDesignFlatButton}" Padding="0" Height="24" HorizontalAlignment="Center"
                                    Foreground="{DynamicResource TextSecondaryColor}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="RÉSERVÉ" FontSize="9" FontWeight="Bold"/>
                                    <materialDesign:PackIcon Width="10" Height="10" Margin="3,0,0,0" VerticalAlignment="Center">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Kind" Value="UnfoldMoreHorizontal"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding SortColumn}" Value="StockReserve"/>
                                                            <Condition Binding="{Binding SortAscending}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Kind" Value="ArrowUp"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding SortColumn}" Value="StockReserve"/>
                                                            <Condition Binding="{Binding SortAscending}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Kind" Value="ArrowDown"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="3" Command="{Binding SortCommand}" CommandParameter="StockDisponible"
                                    Style="{StaticResource MaterialDesignFlatButton}" Padding="0" Height="24" HorizontalAlignment="Center"
                                    Foreground="{DynamicResource TextSecondaryColor}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="DISPONIBLE" FontSize="9" FontWeight="Bold"/>
                                    <materialDesign:PackIcon Width="10" Height="10" Margin="3,0,0,0" VerticalAlignment="Center">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Kind" Value="UnfoldMoreHorizontal"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding SortColumn}" Value="StockDisponible"/>
                                                            <Condition Binding="{Binding SortAscending}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Kind" Value="ArrowUp"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding SortColumn}" Value="StockDisponible"/>
                                                            <Condition Binding="{Binding SortAscending}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Kind" Value="ArrowDown"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="4" Command="{Binding SortCommand}" CommandParameter="SeuilAlerte"
                                    Style="{StaticResource MaterialDesignFlatButton}" Padding="0" Height="24" HorizontalAlignment="Center"
                                    Foreground="{DynamicResource TextSecondaryColor}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="SEUIL" FontSize="9" FontWeight="Bold"/>
                                    <materialDesign:PackIcon Width="10" Height="10" Margin="3,0,0,0" VerticalAlignment="Center">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Kind" Value="UnfoldMoreHorizontal"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding SortColumn}" Value="SeuilAlerte"/>
                                                            <Condition Binding="{Binding SortAscending}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Kind" Value="ArrowUp"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding SortColumn}" Value="SeuilAlerte"/>
                                                            <Condition Binding="{Binding SortAscending}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Kind" Value="ArrowDown"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="5" Command="{Binding SortCommand}" CommandParameter="PrixAchat"
                                    Style="{StaticResource MaterialDesignFlatButton}" Padding="0" Height="24" HorizontalAlignment="Center"
                                    Foreground="{DynamicResource TextSecondaryColor}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="PRIX ACHAT" FontSize="9" FontWeight="Bold"/>
                                    <materialDesign:PackIcon Width="10" Height="10" Margin="3,0,0,0" VerticalAlignment="Center">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Kind" Value="UnfoldMoreHorizontal"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding SortColumn}" Value="PrixAchat"/>
                                                            <Condition Binding="{Binding SortAscending}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Kind" Value="ArrowUp"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding SortColumn}" Value="PrixAchat"/>
                                                            <Condition Binding="{Binding SortAscending}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Kind" Value="ArrowDown"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                </StackPanel>
                            </Button>

                            <TextBlock Grid.Column="6" Text="EMPLACEMENT" Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <Button Grid.Column="7" Command="{Binding SortCommand}" CommandParameter="IsAlerte"
                                    Style="{StaticResource MaterialDesignFlatButton}" Padding="0" Height="24" HorizontalAlignment="Center"
                                    Foreground="{DynamicResource TextSecondaryColor}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="STATUT" FontSize="9" FontWeight="Bold"/>
                                    <materialDesign:PackIcon Width="10" Height="10" Margin="3,0,0,0" VerticalAlignment="Center">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Kind" Value="UnfoldMoreHorizontal"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding SortColumn}" Value="IsAlerte"/>
                                                            <Condition Binding="{Binding SortAscending}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Kind" Value="ArrowUp"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding SortColumn}" Value="IsAlerte"/>
                                                            <Condition Binding="{Binding SortAscending}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Kind" Value="ArrowDown"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                </StackPanel>
                            </Button>

                            <TextBlock Grid.Column="8" Text="ACTIONS" Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Liste -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding StocksList}" Margin="14,4,14,14">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBgDarkerColor}" CornerRadius="12" Margin="0,3" Padding="8,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource CardHoverColor}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2.2*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Produit -->
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="36" Height="36" CornerRadius="10" Background="{DynamicResource BorderSubtleColor}" Margin="0,0,10,0">
                                                    <materialDesign:PackIcon Kind="PackageVariantClosed" Foreground="{DynamicResource AccentColor}" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding NomProduit}" Foreground="{DynamicResource TextPrimaryColor}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                                    <TextBlock Text="{Binding Categorie}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Stock physique -->
                                            <TextBlock Grid.Column="1" Text="{Binding StockPhysique}" Foreground="{DynamicResource TextPrimaryColor}" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                            <!-- Réservé -->
                                            <TextBlock Grid.Column="2" Text="{Binding StockReserve}" Foreground="#FF9F43" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                            <!-- Disponible -->
                                            <TextBlock Grid.Column="3" Text="{Binding StockDisponible}" Foreground="#45E3B8" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                            <!-- Seuil -->
                                            <TextBlock Grid.Column="4" Text="{Binding SeuilAlerte}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                            <!-- Prix achat -->
                                            <TextBlock Grid.Column="5" Text="{Binding PrixAchat, StringFormat={}{0:N2} €}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                            <!-- Emplacement -->
                                            <TextBlock Grid.Column="6" Text="{Binding Emplacement}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                            <!-- Statut -->
                                            <Border Grid.Column="7" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="6" Padding="8,3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background">
                                                            <Setter.Value><SolidColorBrush Color="#45E3B8" Opacity="0.15"/></Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAlerte}" Value="True">
                                                                <Setter Property="Background">
                                                                    <Setter.Value><SolidColorBrush Color="#FF5B5B" Opacity="0.15"/></Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="10" FontWeight="Bold" HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="OK"/>
                                                            <Setter Property="Foreground" Value="#45E3B8"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsAlerte}" Value="True">
                                                                    <Setter Property="Text" Value="ALERTE"/>
                                                                    <Setter Property="Foreground" Value="#FF5B5B"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <!-- Actions -->
                                            <StackPanel Grid.Column="8" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Command="{Binding DataContext.OpenAddStockCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                        Width="30" Height="30" Padding="0" ToolTip="Entrée de stock">
                                                    <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Foreground="#45E3B8"/>
                                                </Button>
                                                <Button Command="{Binding DataContext.OpenRemoveStockCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                        Width="30" Height="30" Padding="0" ToolTip="Sortie de stock">
                                                    <materialDesign:PackIcon Kind="Minus" Width="16" Height="16" Foreground="#FF9F43"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- 5. HISTORIQUE MOUVEMENTS -->
                <Border Grid.Row="4" Background="{DynamicResource CardBgColor}" CornerRadius="16" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="0,0,0,1" Padding="22,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="History" Width="18" Height="18" Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Historique des mouvements" Foreground="{DynamicResource TextPrimaryColor}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Border Background="{DynamicResource BorderSubtleColor}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="30 derniers jours" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                                    </Border>
                                </StackPanel>
                                <!-- Statistiques mouvements 30j -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Background="{DynamicResource CardBgDarkerColor}" CornerRadius="10" Padding="12,6" Margin="6,0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ArrowDownBold" Width="14" Height="14" Foreground="#45E3B8" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <StackPanel>
                                                <TextBlock Text="{Binding TotalEntrees30j, StringFormat='{}{0} entrées'}" Foreground="#45E3B8" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding QteTotaleEntrees, StringFormat='{}{0} unités'}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="9"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{DynamicResource CardBgDarkerColor}" CornerRadius="10" Padding="12,6" Margin="6,0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ArrowUpBold" Width="14" Height="14" Foreground="#FF9F43" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <StackPanel>
                                                <TextBlock Text="{Binding TotalSorties30j, StringFormat='{}{0} sorties'}" Foreground="#FF9F43" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding QteTotaleSorties, StringFormat='{}{0} unités'}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="9"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{DynamicResource CardBgDarkerColor}" CornerRadius="10" Padding="12,6" Margin="6,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="TrophyAward" Width="14" Height="14" Foreground="#6C5DD3" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <StackPanel>
                                                <TextBlock Text="Top produit" Foreground="{DynamicResource TextSecondaryColor}" FontSize="9"/>
                                                <TextBlock Text="{Binding ProduitPlusMouvemente}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="11" FontWeight="Bold" MaxWidth="120" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding MouvementsList}" Margin="14,10,14,14">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBgDarkerColor}" CornerRadius="12" Margin="0,3" Padding="16,10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource CardHoverColor}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Icône type -->
                                            <Border Width="34" Height="34" CornerRadius="10" Margin="0,0,12,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background"><Setter.Value><SolidColorBrush Color="#45E3B8" Opacity="0.15"/></Setter.Value></Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEntree}" Value="False">
                                                                <Setter Property="Background"><Setter.Value><SolidColorBrush Color="#FF9F43" Opacity="0.15"/></Setter.Value></Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <materialDesign:PackIcon Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <materialDesign:PackIcon.Style>
                                                        <Style TargetType="materialDesign:PackIcon">
                                                            <Setter Property="Kind" Value="ArrowDownBold"/>
                                                            <Setter Property="Foreground" Value="#45E3B8"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEntree}" Value="False">
                                                                    <Setter Property="Kind" Value="ArrowUpBold"/>
                                                                    <Setter Property="Foreground" Value="#FF9F43"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </materialDesign:PackIcon.Style>
                                                </materialDesign:PackIcon>
                                            </Border>

                                            <!-- Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Produit}" Foreground="{DynamicResource TextPrimaryColor}" FontWeight="SemiBold" FontSize="12"/>
                                                <TextBlock Text="{Binding Motif}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                                            </StackPanel>

                                            <!-- Quantité -->
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontWeight="Bold" FontSize="13" Margin="0,0,20,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#45E3B8"/>
                                                        <Setter Property="Text" Value="{Binding Quantite, StringFormat='+{0}'}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEntree}" Value="False">
                                                                <Setter Property="Foreground" Value="#FF9F43"/>
                                                                <Setter Property="Text" Value="{Binding Quantite, StringFormat='-{0}'}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Stock avant → après -->
                                            <TextBlock Grid.Column="3" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11" VerticalAlignment="Center" Margin="0,0,20,0">
                                                <Run Text="{Binding StockAvant, Mode=OneWay}"/>
                                                <Run Text=" → "/>
                                                <Run Text="{Binding StockApres, Mode=OneWay}"/>
                                            </TextBlock>

                                            <!-- Date -->
                                            <TextBlock Grid.Column="4" Text="{Binding Date, StringFormat='{}{0:dd/MM HH:mm}'}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </materialDesign:DialogHost>
</UserControl>
