<UserControl x:Class="GroupyV.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1200" Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden">
        <Grid Margin="30,20,30,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding UserName, StringFormat='Bonjour, {0} 👋'}" 
                               Foreground="{DynamicResource TextPrimaryColor}" FontSize="26" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <materialDesign:PackIcon Kind="CalendarClock" Foreground="{DynamicResource TextSecondaryColor}" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding SessionInfo}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Background="{DynamicResource CardBgColor}" CornerRadius="14" Padding="12,8,18,8" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="38" Height="38" CornerRadius="19" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6C5DD3" Offset="0"/>
                                    <GradientStop Color="#8F7CEC" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="{Binding UserInitials}" Foreground="White" FontSize="14" FontWeight="Bold" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding UserName}" Foreground="{DynamicResource TextPrimaryColor}" FontWeight="SemiBold" FontSize="13"/>
                            <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                <Border Width="7" Height="7" CornerRadius="4" Background="#00E676" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding UserRole}" Foreground="#00E676" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 2. CARTES KPI -->
            <Grid Grid.Row="1" Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CA -->
                <Border Grid.Column="0" CornerRadius="16" Padding="20,16" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1" Background="{DynamicResource CardBgColor}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Width="40" Height="40" CornerRadius="12" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Border.Background>
                                <SolidColorBrush Color="#6C5DD3" Opacity="0.2"/>
                            </Border.Background>
                            <materialDesign:PackIcon Kind="CurrencyEur" Width="22" Height="22" Foreground="#6C5DD3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" Text="{Binding TotalCA}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Grid.Row="2" Text="Chiffre d'affaires" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11" Margin="0,2,0,0"/>
                    </Grid>
                </Border>

                <!-- Commandes -->
                <Border Grid.Column="2" CornerRadius="16" Padding="20,16" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1" Background="{DynamicResource CardBgColor}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Width="40" Height="40" CornerRadius="12" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Border.Background>
                                <SolidColorBrush Color="#FF9F43" Opacity="0.2"/>
                            </Border.Background>
                            <materialDesign:PackIcon Kind="CartOutline" Width="22" Height="22" Foreground="#FF9F43" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" Text="{Binding CommandesEnAttente}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Grid.Row="2" Text="Commandes en cours" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11" Margin="0,2,0,0"/>
                    </Grid>
                </Border>

                <!-- Stock -->
                <Border Grid.Column="4" CornerRadius="16" Padding="20,16" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1" Background="{DynamicResource CardBgColor}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Width="40" Height="40" CornerRadius="12" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Border.Background>
                                <SolidColorBrush Color="#FF5B5B" Opacity="0.2"/>
                            </Border.Background>
                            <materialDesign:PackIcon Kind="AlertCircleOutline" Width="22" Height="22" Foreground="#FF5B5B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" Text="{Binding StockFaible}" Foreground="#FF5B5B" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Grid.Row="2" Text="Alertes stock" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11" Margin="0,2,0,0"/>
                    </Grid>
                </Border>

                <!-- SAV -->
                <Border Grid.Column="6" CornerRadius="16" Padding="20,16" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1" Background="{DynamicResource CardBgColor}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Width="40" Height="40" CornerRadius="12" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Border.Background>
                                <SolidColorBrush Color="#45E3B8" Opacity="0.2"/>
                            </Border.Background>
                            <materialDesign:PackIcon Kind="MessageTextOutline" Width="22" Height="22" Foreground="#45E3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" Text="{Binding Signalements}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Grid.Row="2" Text="Messages SAV" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11" Margin="0,2,0,0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- 3. GRAPHIQUE + TOP PRODUITS -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Graphique des ventes -->
                <Border Grid.Column="0" Background="{DynamicResource CardBgColor}" CornerRadius="16" Padding="22,18" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MinHeight="280"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                            <materialDesign:PackIcon Kind="ChartLineVariant" Width="20" Height="20" Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Analyse des ventes" Foreground="{DynamicResource TextPrimaryColor}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Border Background="{DynamicResource BorderSubtleColor}" CornerRadius="8" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="30 derniers jours" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                                <Border Width="10" Height="3" CornerRadius="1" Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Border.Background>
                                        <SolidColorBrush Color="#6C5DD3"/>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="Ventes" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" Margin="0,0,12,0"/>
                                <Border Width="10" Height="3" CornerRadius="1" Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Border.Background>
                                        <SolidColorBrush Color="#45E3B8"/>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="CA (€)" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>

                        <lvc:CartesianChart Grid.Row="1" Series="{Binding ChartSeries}" LegendLocation="None" Margin="0,0,0,5">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding ChartLabels}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Step="1" StrokeThickness="0"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="Ventes" Foreground="#6C5DD3" MinValue="0" FontSize="10" Position="LeftBottom">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Stroke="{DynamicResource BorderSubtleColor}" StrokeDashArray="4 2"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                                <lvc:Axis Title="CA (€)" Foreground="#45E3B8" MinValue="0" FontSize="10" Position="RightTop">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator StrokeThickness="0"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </Border>

                <!-- Top Produits -->
                <Border Grid.Column="2" Background="{DynamicResource CardBgColor}" CornerRadius="16" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="0,0,0,1" Padding="20,16">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TrophyAward" Width="20" Height="20" Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Top Produits" Foreground="{DynamicResource TextPrimaryColor}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                            <ItemsControl ItemsSource="{Binding TopProduits}" Margin="12,10,12,12">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,3" Padding="12,10" CornerRadius="12" Background="{DynamicResource CardBgDarkerColor}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource CardHoverColor}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10" Margin="0,0,12,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#6C5DD3" Opacity="0.15"/>
                                                    </Border.Background>
                                                    <materialDesign:PackIcon Kind="PackageVariantClosed" Foreground="{DynamicResource AccentColor}" Width="18" Height="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Nom}" Foreground="{DynamicResource TextPrimaryColor}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Ventes, StringFormat='{}{0} ventes'}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" Margin="0,1,0,0"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" Text="{Binding CA, StringFormat='{}{0:N0} €'}" Foreground="#45E3B8" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- 4. ALERTES STOCK -->
            <Border Grid.Row="3" Background="{DynamicResource CardBgColor}" CornerRadius="16" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1" Margin="0,18,0,0"
                    Visibility="{Binding HasStockAlerts, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Titre -->
                    <Border BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="0,0,0,1" Padding="22,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="10" Margin="0,0,12,0">
                                    <Border.Background><SolidColorBrush Color="#FF5B5B" Opacity="0.15"/></Border.Background>
                                    <materialDesign:PackIcon Kind="AlertCircleOutline" Width="18" Height="18" Foreground="#FF5B5B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Alertes stock" Foreground="{DynamicResource TextPrimaryColor}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Border Background="#FF5B5B" CornerRadius="10" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StockAlerts.Count}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="Produits en dessous du seuil d'alerte" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Liste des alertes -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding StockAlerts}" Margin="14,10,14,14">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBgDarkerColor}" CornerRadius="12" Margin="0,3" Padding="14,10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource CardHoverColor}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icône -->
                                        <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0">
                                            <Border.Background><SolidColorBrush Color="#FF5B5B" Opacity="0.15"/></Border.Background>
                                            <materialDesign:PackIcon Kind="PackageVariantClosed" Width="16" Height="16" Foreground="#FF5B5B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Nom produit + catégorie -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding NomProduit}" Foreground="{DynamicResource TextPrimaryColor}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Categorie}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                                        </StackPanel>

                                        <!-- Stock actuel / seuil -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                            <TextBlock Text="{Binding StockPhysique}" Foreground="#FF5B5B" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding SeuilAlerte, StringFormat=' / {0}'}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Badge -->
                                        <Border Grid.Column="3" CornerRadius="6" Padding="8,3" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background">
                                                        <Setter.Value><SolidColorBrush Color="#FF5B5B" Opacity="0.15"/></Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRupture}" Value="True">
                                                            <Setter Property="Background">
                                                                <Setter.Value><SolidColorBrush Color="#FF5B5B" Opacity="0.3"/></Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="STOCK BAS"/>
                                                        <Setter Property="Foreground" Value="#FF9F43"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRupture}" Value="True">
                                                                <Setter Property="Text" Value="RUPTURE"/>
                                                                <Setter Property="Foreground" Value="#FF5B5B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>