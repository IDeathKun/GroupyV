<UserControl x:Class="GroupyV.Views.OrderDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:GroupyV.Helpers"
             xmlns:converters="clr-namespace:GroupyV.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <helpers:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis" />
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>
    </UserControl.Resources>

    <!-- DIALOG CONFIRMATION -->
    <materialDesign:DialogHost IsOpen="{Binding IsAnyDialogOpen}" DialogTheme="Dark" OverlayBackground="#CC0F111A">
        <materialDesign:DialogHost.DialogContent>
            <Border Background="{DynamicResource CardBgColor}" CornerRadius="20" Padding="40" Width="460" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.6" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <Border Width="70" Height="70" CornerRadius="35" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6C5DD3" Offset="0"/>
                                <GradientStop Color="#8F7CEC" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <materialDesign:PackIcon Kind="TruckCheckOutline" Width="34" Height="34" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Confirmer l'expédition ?" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Le colis sera marqué comme expédié. Cette action est irréversible." TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextSecondaryColor}" Margin="0,10,0,28" FontSize="13"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Annuler" Command="{Binding CloseDialogCommand}" 
                                Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextSecondaryColor}" Height="44" materialDesign:ButtonAssist.CornerRadius="10"/>
                        <Button Grid.Column="2" Content="OUI, EXPÉDIER" Command="{Binding ExecuteShippingCommand}" Foreground="White" FontWeight="Bold" Height="44" materialDesign:ButtonAssist.CornerRadius="10">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#6C5DD3" Offset="0"/>
                                    <GradientStop Color="#8F7CEC" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </materialDesign:DialogHost.DialogContent>

        <ScrollViewer VerticalScrollBarVisibility="Hidden">
            <Grid Margin="30,20,30,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 1. HEADER -->
                <Grid Grid.Row="0" Margin="0,0,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Command="{Binding GoBackCommand}" Style="{StaticResource MaterialDesignIconForegroundButton}" Foreground="{DynamicResource TextPrimaryColor}" Margin="0,0,14,0" VerticalAlignment="Top" Cursor="Hand">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="28" Height="28"/>
                    </Button>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Détail de la commande" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryColor}"/>
                            <Border Background="{DynamicResource BorderSubtleColor}" CornerRadius="6" Padding="10,3" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Order.IdPrevente, StringFormat='#{0}'}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                            <Border CornerRadius="6" Padding="10,3" Margin="6,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding IsShipped, Converter={StaticResource BoolToVis}}">
                                <Border.Background>
                                    <SolidColorBrush Color="#00E676" Opacity="0.15"/>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckCircleOutline" Width="13" Height="13" Foreground="#00E676" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="EXPÉDIÉ" Foreground="#00E676" FontSize="11" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Visualisez le récapitulatif et gérez l'expédition." Foreground="{DynamicResource TextSecondaryColor}" FontSize="12" Margin="0,3,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- 2. RÉCAP : Produit + Client + Montant -->
                <Grid Grid.Row="1" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Carte Produit -->
                    <Border Grid.Column="0" Background="{DynamicResource CardBgColor}" CornerRadius="14" Padding="18" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12" Margin="0,0,14,0" Background="{DynamicResource CardBgDarkerColor}" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                                <Grid ClipToBounds="True">
                                    <materialDesign:PackIcon Kind="PackageVariantClosed" Foreground="{DynamicResource InputBorderColor}" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Image Source="{Binding Order.Produit.Image, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="PRODUIT" Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Order.Produit.NomProduit}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="14" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Order.Statut}" Foreground="#FFB74D" FontSize="11"/>
                                    <TextBlock Text="{Binding Order.DateLimite, StringFormat=' • Limite : {0:dd/MM/yy}'}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Carte Client -->
                    <Border Grid.Column="2" Background="{DynamicResource CardBgColor}" CornerRadius="14" Padding="18" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24" Margin="0,0,14,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#6C5DD3" Offset="0"/>
                                        <GradientStop Color="#8F7CEC" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="{Binding ClientInitiales}" Foreground="White" FontSize="16" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="CLIENT" Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" FontWeight="Bold"/>
                                <TextBlock Text="{Binding ClientNomComplet}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="14" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <materialDesign:PackIcon Kind="EmailOutline" Width="12" Foreground="{DynamicResource TextSecondaryColor}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ClientEmail}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Carte Montant -->
                    <Border Grid.Column="4" Background="{DynamicResource CardBgColor}" CornerRadius="14" Padding="22,18" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1" MinWidth="160">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="MONTANT" Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Order.PrixPrevente, StringFormat={}{0:N2} €}" FontSize="28" FontWeight="Bold" Foreground="#45E3B8" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding ParticipantsList.Count, StringFormat='{}{0} participant(s)'}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 3. LISTE D'EXPÉDITION -->
                <Border Grid.Row="2" Background="{DynamicResource CardBgColor}" CornerRadius="16" Margin="0,0,0,18" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Titre section -->
                        <Border BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="0,0,0,1" Padding="22,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ClipboardListOutline" Width="18" Height="18" Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Bordereaux d'expédition" Foreground="{DynamicResource TextPrimaryColor}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Border Background="{DynamicResource BorderSubtleColor}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ParticipantsList.Count, StringFormat='{}{0} colis'}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Command="{Binding PrintAllShippingLabelsCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource AccentColor}"
                                        Height="30" Padding="10,0" materialDesign:ButtonAssist.CornerRadius="8">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Printer" Width="14" Margin="0,0,5,0"/>
                                        <TextBlock Text="Tout imprimer" FontSize="10" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Liste des participants -->
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding ParticipantsList}" Margin="14,10,14,14">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBgDarkerColor}" CornerRadius="12" Margin="0,3" Padding="16,12">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource CardHoverColor}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Avatar -->
                                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19" Background="{DynamicResource BorderSubtleColor}" Margin="0,0,12,0">
                                                <materialDesign:PackIcon Kind="Account" Foreground="{DynamicResource TextPrimaryColor}" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Infos destinataire -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Client.Prenom}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryColor}" FontSize="13"/>
                                                    <TextBlock Text=" "/>
                                                    <TextBlock Text="{Binding Client.Nom}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryColor}" FontSize="13"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <materialDesign:PackIcon Kind="MapMarkerOutline" Width="12" Foreground="{DynamicResource TextSecondaryColor}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Client.Adresse}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                                                    <TextBlock Text="  •  " Foreground="{DynamicResource TextSecondaryColor}" FontSize="11"/>
                                                    <materialDesign:PackIcon Kind="PhoneOutline" Width="12" Foreground="{DynamicResource TextSecondaryColor}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Client.Phone}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Email -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                                <materialDesign:PackIcon Kind="EmailOutline" Width="13" Foreground="{DynamicResource TextSecondaryColor}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Client.Email}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11"/>
                                            </StackPanel>

                                            <!-- Bouton Imprimer bordereau -->
                                            <Button Grid.Column="3"
                                                    Command="{Binding DataContext.PrintShippingLabelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource AccentColor}"
                                                    Height="30" Padding="10,0" Margin="0,0,8,0" materialDesign:ButtonAssist.CornerRadius="8">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Printer" Width="14" Margin="0,0,5,0"/>
                                                    <TextBlock Text="Bordereau" FontSize="10" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Bouton Facture -->
                                            <Button Grid.Column="4" 
                                                    Command="{Binding DataContext.OpenInvoiceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource AccentColor}"
                                                    Height="30" Padding="10,0" materialDesign:ButtonAssist.CornerRadius="8">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="FileDocumentOutline" Width="14" Margin="0,0,5,0"/>
                                                    <TextBlock Text="Facture" FontSize="10" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- 4. ZONE EXPÉDITION -->
                <Grid Grid.Row="3">

                    <!-- Formulaire (si PAS encore expédié) -->
                    <Border Background="{DynamicResource CardBgColor}" CornerRadius="16" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1"
                            Visibility="{Binding IsShipped, Converter={StaticResource InvBoolToVis}}">
                        <Grid Margin="24,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Titre -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,18">
                                <materialDesign:PackIcon Kind="TruckFastOutline" Foreground="{DynamicResource AccentColor}" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Configuration de l'envoi" Foreground="{DynamicResource TextPrimaryColor}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Champs formulaire -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0" ItemsSource="{Binding Carriers}" SelectedItem="{Binding SelectedCarrier}"
                                          materialDesign:HintAssist.Hint="Transporteur"
                                          materialDesign:HintAssist.Foreground="{DynamicResource TextSecondaryColor}"
                                          materialDesign:HintAssist.IsFloating="True"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}" BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextPrimaryColor}" MinHeight="56">
                                    <ComboBox.Resources>
                                        <SolidColorBrush x:Key="MaterialDesignPaper" Color="#1A1C2E"/>
                                        <SolidColorBrush x:Key="MaterialDesignBody"  Color="White"/>
                                    </ComboBox.Resources>
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource MaterialDesignComboBoxItemStyle}">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsHighlighted" Value="True">
                                                    <Setter Property="Background" Value="#2D304D"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#2D304D"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="{Binding Icon}" Margin="0,0,8,0" Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryColor}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBox Grid.Column="2" Text="{Binding AutoTrackingNumber}" IsReadOnly="True"
                                         materialDesign:HintAssist.Hint="N° de suivi"
                                         materialDesign:HintAssist.IsFloating="True"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextSecondaryColor}" MinHeight="56" VerticalContentAlignment="Center"/>

                                <TextBox Grid.Column="4" Text="{Binding WeightInput}" 
                                         materialDesign:HintAssist.Hint="Poids (kg)"
                                         materialDesign:HintAssist.IsFloating="True"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextPrimaryColor}" MinHeight="56" VerticalContentAlignment="Center"/>

                                <TextBox Grid.Column="6" Text="{Binding DimensionsInput}" 
                                         materialDesign:HintAssist.Hint="Dimensions"
                                         materialDesign:HintAssist.IsFloating="True"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextPrimaryColor}" MinHeight="56" VerticalContentAlignment="Center"/>
                            </Grid>

                            <!-- Bouton expédier -->
                            <Button Grid.Row="2" Command="{Binding OpenConfirmDialogCommand}" Height="48" materialDesign:ButtonAssist.CornerRadius="12"
                                    HorizontalAlignment="Right" Padding="28,0" Margin="0,18,0,0" Cursor="Hand">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#6C5DD3" Offset="0"/>
                                        <GradientStop Color="#8F7CEC" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <Button.Effect>
                                    <DropShadowEffect Color="#6C5DD3" BlurRadius="20" ShadowDepth="4" Opacity="0.35"/>
                                </Button.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="RocketLaunchOutline" Width="20" Height="20" Margin="0,0,10,0"/>
                                    <TextBlock Text="CONFIRMER L'EXPÉDITION" FontWeight="Bold" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Bandeau succès (si DÉJÀ expédié) -->
                    <Border CornerRadius="16" Visibility="{Binding IsShipped, Converter={StaticResource BoolToVis}}" BorderBrush="#2E6B45" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#142E1E" Offset="0"/>
                                <GradientStop Color="#1A3D28" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Margin="26,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icône succès -->
                            <Border Grid.Column="0" Width="56" Height="56" CornerRadius="28" Margin="0,0,22,0" VerticalAlignment="Center">
                                <Border.Background>
                                    <SolidColorBrush Color="#00E676" Opacity="0.15"/>
                                </Border.Background>
                                <materialDesign:PackIcon Kind="CheckCircle" Width="28" Height="28" Foreground="#00E676" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Infos expédition -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Expédition confirmée" Foreground="White" FontSize="17" FontWeight="Bold" Margin="0,0,0,6"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Transporteur" Foreground="#6BAF7E" FontSize="10" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CurrentExpedition.Transporteur}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Tracking" Foreground="#6BAF7E" FontSize="10" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CurrentExpedition.NumeroTracking}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Livraison estimée" Foreground="#6BAF7E" FontSize="10" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CurrentExpedition.DateLivraisonPrevue, StringFormat='{}{0:dd/MM/yyyy}'}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </materialDesign:DialogHost>
</UserControl>