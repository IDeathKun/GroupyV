<UserControl x:Class="GroupyV.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden">
        <Grid Margin="30,20,30,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══════ HEADER ═══════ -->
            <Grid Grid.Row="0" Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Paramètres" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryColor}"/>
                    <TextBlock Text="Gérez votre profil, votre entreprise et personnalisez l'interface." Foreground="{DynamicResource TextSecondaryColor}" FontSize="12" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Toast status -->
                <Border Grid.Column="1" CornerRadius="10" Padding="14,8" VerticalAlignment="Center"
                        Visibility="{Binding ShowStatus, Converter={StaticResource BoolToVis}}">
                    <Border.Background><SolidColorBrush Color="#45E3B8" Opacity="0.15"/></Border.Background>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircleOutline" Width="16" Height="16" Foreground="#45E3B8" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#45E3B8" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══════ 1. THÈME : Mode sombre / clair ═══════ -->
            <Border Grid.Row="1" Background="{DynamicResource CardBgColor}" CornerRadius="16" Margin="0,0,0,18" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                <Grid Margin="22,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icône + Texte -->
                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="14" Margin="0,0,18,0">
                        <Border.Background><SolidColorBrush Color="#6C5DD3" Opacity="0.15"/></Border.Background>
                        <materialDesign:PackIcon Kind="{Binding ThemeIcon}" Width="24" Height="24" Foreground="{DynamicResource AccentColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Apparence" Foreground="{DynamicResource TextPrimaryColor}" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Foreground="{DynamicResource TextSecondaryColor}" FontSize="12" Margin="0,2,0,0">
                            <Run Text="Thème actuel :"/>
                            <Run Text="{Binding ThemeLabel, Mode=OneWay}" FontWeight="SemiBold"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Toggle -->
                    <Button Grid.Column="2" Command="{Binding ToggleThemeCommand}" Height="44" Padding="20,0"
                            materialDesign:ButtonAssist.CornerRadius="12" Foreground="White" FontWeight="Bold" Cursor="Hand">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#6C5DD3" Offset="0"/>
                                <GradientStop Color="#8F7CEC" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="{Binding ThemeIcon}" Width="18" Height="18" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding ThemeLabel}" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══════ 2. PROFIL UTILISATEUR ═══════ -->
            <Border Grid.Row="2" Background="{DynamicResource CardBgColor}" CornerRadius="16" Margin="0,0,0,18" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                <StackPanel>
                    <Border BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="0,0,0,1" Padding="22,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="10" Margin="0,0,12,0">
                                    <Border.Background><SolidColorBrush Color="#45E3B8" Opacity="0.2"/></Border.Background>
                                    <materialDesign:PackIcon Kind="AccountCircle" Width="18" Height="18" Foreground="#45E3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Mon profil" Foreground="{DynamicResource TextPrimaryColor}" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DateInscription}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Column="1" Width="48" Height="48" CornerRadius="24">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#6C5DD3" Offset="0"/>
                                        <GradientStop Color="#8F7CEC" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="{Binding Initiales}" Foreground="White" FontSize="16" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Margin="22,18,22,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,14">
                            <TextBlock Text="NOM" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Nom" materialDesign:HintAssist.Foreground="{DynamicResource TextSecondaryColor}"
                                     BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextPrimaryColor}" MinHeight="56" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14">
                            <TextBlock Text="PRÉNOM" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Prenom, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Prénom" materialDesign:HintAssist.Foreground="{DynamicResource TextSecondaryColor}"
                                     BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextPrimaryColor}" MinHeight="56" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,14">
                            <TextBlock Text="EMAIL" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Email" materialDesign:HintAssist.Foreground="{DynamicResource TextSecondaryColor}"
                                     BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextPrimaryColor}" MinHeight="56" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,14">
                            <TextBlock Text="TÉLÉPHONE" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Téléphone" materialDesign:HintAssist.Foreground="{DynamicResource TextSecondaryColor}"
                                     BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextPrimaryColor}" MinHeight="56" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Margin="0,0,0,14">
                            <TextBlock Text="ADRESSE" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Adresse, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Adresse" materialDesign:HintAssist.Foreground="{DynamicResource TextSecondaryColor}"
                                     BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextPrimaryColor}" MinHeight="56" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Row="3" Grid.ColumnSpan="3" HorizontalAlignment="Right"
                                Command="{Binding SaveProfileCommand}" Height="40" Padding="24,0"
                                materialDesign:ButtonAssist.CornerRadius="10" Foreground="White" FontWeight="Bold" Cursor="Hand">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#6C5DD3" Offset="0"/>
                                    <GradientStop Color="#8F7CEC" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16" Margin="0,0,8,0"/>
                                <TextBlock Text="Enregistrer le profil" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════ 3. INFORMATIONS ENTREPRISE ═══════ -->
            <Border Grid.Row="3" Background="{DynamicResource CardBgColor}" CornerRadius="16" Margin="0,0,0,18" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                <StackPanel>
                    <Border BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="0,0,0,1" Padding="22,16">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" CornerRadius="10" Margin="0,0,12,0">
                                <Border.Background><SolidColorBrush Color="#FF9F43" Opacity="0.2"/></Border.Background>
                                <materialDesign:PackIcon Kind="OfficeBuildingMarker" Width="18" Height="18" Foreground="#FF9F43" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Mon entreprise" Foreground="{DynamicResource TextPrimaryColor}" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Informations légales et de contact" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Grid Margin="22,18,22,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,14">
                            <TextBlock Text="NOM ENTREPRISE" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NomEntreprise, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Nom entreprise" materialDesign:HintAssist.Foreground="{DynamicResource TextSecondaryColor}"
                                     BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextPrimaryColor}" MinHeight="56" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,14">
                            <TextBlock Text="SIRET" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Siret, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Numéro SIRET" materialDesign:HintAssist.Foreground="{DynamicResource TextSecondaryColor}"
                                     BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextPrimaryColor}" MinHeight="56" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,14">
                            <TextBlock Text="EMAIL PROFESSIONNEL" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding EmailPro, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Email professionnel" materialDesign:HintAssist.Foreground="{DynamicResource TextSecondaryColor}"
                                     BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextPrimaryColor}" MinHeight="56" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,14">
                            <TextBlock Text="ADRESSE ENTREPRISE" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding AdresseEntreprise, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Adresse entreprise" materialDesign:HintAssist.Foreground="{DynamicResource TextSecondaryColor}"
                                     BorderBrush="{DynamicResource InputBorderColor}" Foreground="{DynamicResource TextPrimaryColor}" MinHeight="56" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Row="2" Grid.ColumnSpan="3" HorizontalAlignment="Right"
                                Command="{Binding SaveEntrepriseCommand}" Height="40" Padding="24,0"
                                materialDesign:ButtonAssist.CornerRadius="10" Foreground="White" FontWeight="Bold" Cursor="Hand">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF9F43" Offset="0"/>
                                    <GradientStop Color="#FFB347" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16" Margin="0,0,8,0"/>
                                <TextBlock Text="Enregistrer l'entreprise" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════ 4. INFOS SESSION ═══════ -->
            <Border Grid.Row="4" Background="{DynamicResource CardBgColor}" CornerRadius="16" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                <Border Padding="22,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="32" Height="32" CornerRadius="10" Margin="0,0,12,0">
                                    <Border.Background><SolidColorBrush Color="#3B82F6" Opacity="0.2"/></Border.Background>
                                    <materialDesign:PackIcon Kind="InformationOutline" Width="18" Height="18" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Informations de session" Foreground="{DynamicResource TextPrimaryColor}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="44,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="UTILISATEUR" Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding NomComplet}" Foreground="{DynamicResource TextPrimaryColor}" FontWeight="SemiBold" FontSize="13"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="SESSION" Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SessionInfo}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="12"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="VERSION" Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" FontWeight="Bold"/>
                                    <TextBlock Text="GroupyV v1.0.0" Foreground="{DynamicResource TextPrimaryColor}" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Border Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="8" Height="8" CornerRadius="4" Background="#00E676" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Session active" Foreground="#00E676" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
