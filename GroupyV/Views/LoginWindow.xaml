<Window x:Class="GroupyV.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:GroupyV.ViewModels" 
        Title="GroupyV - Connexion" Height="450" Width="800"
        WindowStyle="None" ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="Transparent" AllowsTransparency="True">

    <Window.DataContext>
        <vm:LoginViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border CornerRadius="20" Background="White" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="20,0,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1C2E" Offset="0"/>
                        <GradientStop Color="#6C5DD3" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="RocketLaunch" Foreground="White" Width="60" Height="60" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="GroupyV" Foreground="White" FontSize="38" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="ESPACE VENDEUR" Foreground="#CCCCCC" FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" Margin="40">
                <Button Content="✕" HorizontalAlignment="Right" Style="{StaticResource MaterialDesignFlatButton}" 
                        Foreground="Gray" Click="Close_Click" Margin="0,-20,-20,0"/>

                <TextBlock Text="Connexion" FontSize="26" FontWeight="Bold" Margin="0,10,0,30"/>

                <TextBox materialDesign:HintAssist.Hint="Email professionnel" 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>

                <PasswordBox x:Name="txtPassword" 
                             materialDesign:HintAssist.Hint="Mot de passe" 
                             Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" 
                             Margin="0,0,0,30"/>

                <Button Content="SE CONNECTER" Height="45" 
                        Command="{Binding LoginCommand}" 
                        CommandParameter="{Binding ElementName=txtPassword}"
                        Style="{StaticResource MaterialDesignRaisedButton}" 
                        materialDesign:ButtonAssist.CornerRadius="10"
                        Background="#6C5DD3" BorderThickness="0"
                        IsDefault="True"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center" Margin="0,15,0,0"
                           Visibility="{Binding ErrorVisibility, FallbackValue=Collapsed}"/>
            </StackPanel>

            <Border Grid.ColumnSpan="2" Background="#AA0F111A" CornerRadius="20"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid Width="72" Height="72" Margin="0,0,0,10">
                        <Ellipse Stroke="#55FFFFFF" StrokeThickness="6"/>
                        <materialDesign:PackIcon Kind="Loading" Width="42" Height="42" Foreground="#6C5DD3"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <materialDesign:PackIcon.RenderTransform>
                                <RotateTransform/>
                            </materialDesign:PackIcon.RenderTransform>
                            <materialDesign:PackIcon.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                             From="0" To="360" Duration="0:0:1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </materialDesign:PackIcon.Triggers>
                        </materialDesign:PackIcon>
                    </Grid>
                    <TextBlock Text="Connexion en cours..." Foreground="White" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>