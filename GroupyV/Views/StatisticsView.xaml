<UserControl x:Class="GroupyV.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:helpers="clr-namespace:GroupyV.Helpers"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis"/>

        <!-- Bouton mode graphique actif -->
        <Style x:Key="ChartModeBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height"    Value="28"/>
            <Setter Property="Padding"   Value="12,0"/>
            <Setter Property="FontSize"  Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
        </Style>
        <Style x:Key="ChartModeBtnActive" TargetType="Button" BasedOn="{StaticResource ChartModeBtn}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#6C5DD3"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden">
        <Grid Margin="30,20,30,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 0 Header          -->
                <RowDefinition Height="Auto"/>  <!-- 1 KPIs ligne 1    -->
                <RowDefinition Height="12"/>    <!-- 2 Espacement       -->
                <RowDefinition Height="Auto"/>  <!-- 3 KPIs ligne 2    -->
                <RowDefinition Height="Auto"/>  <!-- 4 Graphique CA    -->
                <RowDefinition Height="Auto"/>  <!-- 5 Top produits    -->
                <RowDefinition Height="Auto"/>  <!-- 6 Mouvements      -->
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════════════
                 0. HEADER
            ══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Statistiques &amp; Analyses" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryColor}"/>
                    <TextBlock Text="Vue d'ensemble de vos performances de vente et de stock."
                               Foreground="{DynamicResource TextSecondaryColor}" FontSize="12" Margin="0,3,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding RefreshCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        BorderBrush="{DynamicResource InputBorderColor}"
                        Foreground="{DynamicResource TextSecondaryColor}"
                        Height="36" materialDesign:ButtonAssist.CornerRadius="10" Padding="14,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="Actualiser" FontSize="11"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════
                 1. KPIs LIGNE 1  — CA Total / CA Mois / Ventes / Panier
            ══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CA Total -->
                <Border Grid.Column="0" Background="{DynamicResource CardBgColor}" CornerRadius="14"
                        Padding="16,14" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <StackPanel>
                        <Border Width="32" Height="32" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Border.Background><SolidColorBrush Color="#6C5DD3" Opacity="0.2"/></Border.Background>
                            <materialDesign:PackIcon Kind="CurrencyEur" Width="16" Height="16" Foreground="#6C5DD3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding CATotal}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="CA Total" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                    </StackPanel>
                </Border>

                <!-- CA Mois -->
                <Border Grid.Column="2" Background="{DynamicResource CardBgColor}" CornerRadius="14"
                        Padding="16,14" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <StackPanel>
                        <Border Width="32" Height="32" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Border.Background><SolidColorBrush Color="#45E3B8" Opacity="0.2"/></Border.Background>
                            <materialDesign:PackIcon Kind="CalendarMonth" Width="16" Height="16" Foreground="#45E3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding CAMoisEnCours}" Foreground="#45E3B8" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="CA ce mois" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                    </StackPanel>
                </Border>

                <!-- Total ventes -->
                <Border Grid.Column="4" Background="{DynamicResource CardBgColor}" CornerRadius="14"
                        Padding="16,14" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <StackPanel>
                        <Border Width="32" Height="32" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Border.Background><SolidColorBrush Color="#FF9F43" Opacity="0.2"/></Border.Background>
                            <materialDesign:PackIcon Kind="CartCheck" Width="16" Height="16" Foreground="#FF9F43" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding TotalVentes}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Ventes totales" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                    </StackPanel>
                </Border>

                <!-- Panier moyen -->
                <Border Grid.Column="6" Background="{DynamicResource CardBgColor}" CornerRadius="14"
                        Padding="16,14" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <StackPanel>
                        <Border Width="32" Height="32" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Border.Background><SolidColorBrush Color="#3B82F6" Opacity="0.2"/></Border.Background>
                            <materialDesign:PackIcon Kind="ShoppingOutline" Width="16" Height="16" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding PanierMoyen, StringFormat='{}{0:N2} €'}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Panier moyen" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════
                 3. KPIs LIGNE 2  — Taux / Clients / Produits / Préventes
            ══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Taux conversion -->
                <Border Grid.Column="0" Background="{DynamicResource CardBgColor}" CornerRadius="14"
                        Padding="16,14" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <StackPanel>
                        <Border Width="32" Height="32" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Border.Background><SolidColorBrush Color="#10B981" Opacity="0.2"/></Border.Background>
                            <materialDesign:PackIcon Kind="ChartArc" Width="16" Height="16" Foreground="#10B981" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding TauxConversion, StringFormat='{}{0}%'}" Foreground="#10B981" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Taux conversion" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                    </StackPanel>
                </Border>

                <!-- Clients uniques -->
                <Border Grid.Column="2" Background="{DynamicResource CardBgColor}" CornerRadius="14"
                        Padding="16,14" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <StackPanel>
                        <Border Width="32" Height="32" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Border.Background><SolidColorBrush Color="#EC4899" Opacity="0.2"/></Border.Background>
                            <materialDesign:PackIcon Kind="AccountGroup" Width="16" Height="16" Foreground="#EC4899" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding TotalClients}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Clients uniques" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                    </StackPanel>
                </Border>

                <!-- Nb produits -->
                <Border Grid.Column="4" Background="{DynamicResource CardBgColor}" CornerRadius="14"
                        Padding="16,14" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <StackPanel>
                        <Border Width="32" Height="32" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Border.Background><SolidColorBrush Color="#F59E0B" Opacity="0.2"/></Border.Background>
                            <materialDesign:PackIcon Kind="PackageVariantClosed" Width="16" Height="16" Foreground="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding TotalProduits}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Produits actifs" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                    </StackPanel>
                </Border>

                <!-- Préventes en cours — avec tooltip liste détaillée -->
                <Border Grid.Column="6" Background="{DynamicResource CardBgColor}" CornerRadius="14"
                        Padding="16,14" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1"
                        Cursor="Help">
                    <Border.ToolTip>
                        <ToolTip DataContext="{Binding Path=PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <Border Background="#1A1A2E" CornerRadius="12" Padding="16,12" MinWidth="300" MaxWidth="380">
                                <StackPanel>
                                    <!-- Titre tooltip -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <materialDesign:PackIcon Kind="TimerSand" Width="16" Height="16" Foreground="#FF9F43" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Préventes en cours" FontWeight="Bold" FontSize="13" Foreground="White"/>
                                        <Border Background="#FF9F43" CornerRadius="8" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding NbPreventesEnCours}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Liste des préventes -->
                                    <ItemsControl ItemsSource="{Binding PreventesEnCours}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#252540" CornerRadius="8" Padding="10,8" Margin="0,3,0,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding NomProduit}" Foreground="White"
                                                                       FontWeight="SemiBold" FontSize="12"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                <materialDesign:PackIcon Kind="AccountMultiple" Width="11" Height="11" Foreground="#888" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                                                <TextBlock Text="{Binding NbParticipations, StringFormat='{}{0} participant(s)'}"
                                                                           Foreground="#888" FontSize="10"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" Background="#2A2A4A" CornerRadius="6"
                                                                Padding="8,4" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Prix, StringFormat='{}{0:N2} €'}"
                                                                       Foreground="#45E3B8" FontWeight="Bold" FontSize="12"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </ToolTip>
                    </Border.ToolTip>

                    <StackPanel>
                        <Border Width="32" Height="32" CornerRadius="10" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Border.Background><SolidColorBrush Color="#FF9F43" Opacity="0.2"/></Border.Background>
                            <materialDesign:PackIcon Kind="TimerSand" Width="16" Height="16" Foreground="#FF9F43" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding NbPreventesEnCours}" Foreground="#FF9F43" FontSize="18" FontWeight="Bold"/>
                            <materialDesign:PackIcon Kind="InformationOutline" Width="13" Height="13"
                                                     Foreground="{DynamicResource TextSecondaryColor}"
                                                     VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="Préventes en cours" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════
                 4. GRAPHIQUE CA INTERACTIF + PIE STATUTS
            ══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="4" Margin="0,18,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Graphique CA ── -->
                <Border Grid.Column="0" Background="{DynamicResource CardBgColor}" CornerRadius="16"
                        Padding="22,18" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MinHeight="280"/>
                        </Grid.RowDefinitions>

                        <!-- Titre + contrôles mode -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="ChartLine" Width="20" Height="20"
                                                         Foreground="{DynamicResource AccentColor}"
                                                         VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding CAChartTitle}"
                                           Foreground="{DynamicResource TextPrimaryColor}"
                                           FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Boutons de mode -->
                            <Border Grid.Column="1" Background="{DynamicResource CardBgDarkerColor}"
                                    CornerRadius="10" Padding="3">
                                <StackPanel Orientation="Horizontal">
                                    <!-- 6 Mois -->
                                    <Button Command="{Binding SetViewModeCommand}" CommandParameter="SixMois"
                                            ToolTip="6 derniers mois glissants">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ChartModeBtn}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsModeSixMois}" Value="True">
                                                        <Setter Property="Background" Value="#6C5DD3"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CalendarRange" Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="6 mois" FontSize="11"/>
                                        </StackPanel>
                                    </Button>
                                    <!-- Par année -->
                                    <Button Command="{Binding SetViewModeCommand}" CommandParameter="ParAnnee"
                                            ToolTip="Vue mensuelle d'une année">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ChartModeBtn}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsModeParAnnee}" Value="True">
                                                        <Setter Property="Background" Value="#6C5DD3"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Calendar" Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="Année" FontSize="11"/>
                                        </StackPanel>
                                    </Button>
                                    <!-- Multi-années -->
                                    <Button Command="{Binding SetViewModeCommand}" CommandParameter="MultiAnnees"
                                            ToolTip="Comparaison toutes les années">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ChartModeBtn}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsModeMultiAnnees}" Value="True">
                                                        <Setter Property="Background" Value="#6C5DD3"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ChartBar" Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="Historique" FontSize="11"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Sous-titre + navigation année -->
                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Résumé période -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="{DynamicResource BorderSubtleColor}" CornerRadius="8" Padding="8,3">
                                    <TextBlock Text="{Binding CAChartSummary}"
                                               Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                                </Border>
                                <!-- Légende séries -->
                                <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                                    <Border Width="10" Height="3" CornerRadius="1" VerticalAlignment="Center" Margin="0,0,4,0">
                                        <Border.Background><SolidColorBrush Color="#6C5DD3"/></Border.Background>
                                    </Border>
                                    <TextBlock Text="CA" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" Margin="0,0,12,0"/>
                                    <Border Width="10" Height="3" CornerRadius="1" VerticalAlignment="Center" Margin="0,0,4,0">
                                        <Border.Background><SolidColorBrush Color="#45E3B8"/></Border.Background>
                                    </Border>
                                    <TextBlock Text="Participations" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Navigation année — visible seulement en mode ParAnnee -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                        Visibility="{Binding ShowYearNav,
                                            Converter={StaticResource BoolToVis}}">
                                <Button Command="{Binding PreviousYearCommand}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Width="28" Height="28" Padding="0"
                                        ToolTip="Année précédente">
                                    <materialDesign:PackIcon Kind="ChevronLeft" Width="16" Height="16"
                                                             Foreground="{DynamicResource TextSecondaryColor}"/>
                                </Button>
                                <Border Background="{DynamicResource CardBgDarkerColor}" CornerRadius="8"
                                        Padding="14,4" Margin="2,0">
                                    <TextBlock Text="{Binding SelectedYear}" FontSize="14" FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryColor}" VerticalAlignment="Center"/>
                                </Border>
                                <Button Command="{Binding NextYearCommand}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Width="28" Height="28" Padding="0"
                                        ToolTip="Année suivante">
                                    <materialDesign:PackIcon Kind="ChevronRight" Width="16" Height="16"
                                                             Foreground="{DynamicResource TextSecondaryColor}"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Graphique -->
                        <lvc:CartesianChart Grid.Row="2" Series="{Binding CAMensuelSeries}"
                                            LegendLocation="None" Hoverable="True" DataTooltip="{x:Null}">
                            <lvc:CartesianChart.ChartLegend>
                                <lvc:DefaultLegend BulletSize="10"/>
                            </lvc:CartesianChart.ChartLegend>
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding CAMensuelLabels}"
                                          Foreground="{DynamicResource TextSecondaryColor}" FontSize="11">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator StrokeThickness="0"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <!-- Axe Y gauche : CA -->
                                <lvc:Axis LabelFormatter="{Binding CAFormatter}"
                                          Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" MinValue="0"
                                          Position="LeftBottom">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Stroke="{DynamicResource BorderSubtleColor}" StrokeDashArray="4 2"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                                <!-- Axe Y droit : Participations -->
                                <lvc:Axis Foreground="#45E3B8" FontSize="10" MinValue="0"
                                          Position="RightTop" Title="Participations">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator StrokeThickness="0"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </Border>

                <!-- ── Pie statuts + Répartition préventes ── -->
                <Border Grid.Column="2" Background="{DynamicResource CardBgColor}" CornerRadius="16"
                        Padding="22,18" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MinHeight="220"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <materialDesign:PackIcon Kind="ChartDonut" Width="20" Height="20"
                                                     Foreground="{DynamicResource AccentColor}"
                                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Statuts préventes" Foreground="{DynamicResource TextPrimaryColor}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <lvc:PieChart Grid.Row="1" Series="{Binding StatutSeries}"
                                      LegendLocation="Bottom" InnerRadius="50"
                                      Hoverable="True"
                                      Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>

                        <!-- Mini liste préventes en cours sous le pie -->
                        <StackPanel Grid.Row="2" Margin="0,10,0,0">
                            <Border BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="TimerSand" Width="14" Height="14" Foreground="#FF9F43" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="En cours" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Border Background="#FF9F4320" CornerRadius="6" Padding="6,2" Margin="6,0,0,0">
                                        <TextBlock Text="{Binding NbPreventesEnCours}" Foreground="#FF9F43" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <ItemsControl ItemsSource="{Binding PreventesEnCours}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding NomProduit}"
                                                       Foreground="{DynamicResource TextPrimaryColor}"
                                                       FontSize="11" TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding NbParticipations}" Foreground="#45E3B8"
                                                           FontWeight="Bold" FontSize="11" Margin="0,0,2,0"/>
                                                <TextBlock Text="part." Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════
                 5. TOP PRODUITS
            ══════════════════════════════════════════════════════════ -->
            <Border Grid.Row="5" Background="{DynamicResource CardBgColor}" CornerRadius="16"
                    Margin="0,0,0,18" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="0,0,0,1" Padding="22,16">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TrophyAward" Width="20" Height="20" Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Classement produits" Foreground="{DynamicResource TextPrimaryColor}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Border Background="{DynamicResource BorderSubtleColor}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Par chiffre d'affaires" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="22,10,22,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="#"          Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="PRODUIT"    Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="VENTES"     Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="PRÉVENTES"  Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="PRIX MOYEN" Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="CA"         Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Grid>

                    <ItemsControl Grid.Row="2" ItemsSource="{Binding TopProduits}" Margin="14,4,14,14">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBgDarkerColor}" CornerRadius="12" Margin="0,3" Padding="8,10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource CardHoverColor}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding RangIcon}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding NomProduit}" Foreground="{DynamicResource TextPrimaryColor}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Categorie}"  Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding NbVentes}"                                         Foreground="{DynamicResource TextPrimaryColor}" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding NbPreventes}"                                      Foreground="{DynamicResource TextSecondaryColor}" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{Binding PrixMoyen, StringFormat='{}{0:N2} €'}"             Foreground="{DynamicResource TextSecondaryColor}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="{Binding CA,        StringFormat='{}{0:N2} €'}" Foreground="#45E3B8" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════════
                 6. MOUVEMENTS STOCK
            ══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Graphique entrées/sorties -->
                <Border Grid.Column="0" Background="{DynamicResource CardBgColor}" CornerRadius="16"
                        Padding="22,18" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MinHeight="220"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <materialDesign:PackIcon Kind="SwapVertical" Width="20" Height="20" Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Mouvements de stock" Foreground="{DynamicResource TextPrimaryColor}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Border Background="{DynamicResource BorderSubtleColor}" CornerRadius="8" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="4 semaines" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                                <Border Width="10" Height="3" CornerRadius="1" Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Border.Background><SolidColorBrush Color="#45E3B8"/></Border.Background>
                                </Border>
                                <TextBlock Text="Entrées" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" Margin="0,0,12,0"/>
                                <Border Width="10" Height="3" CornerRadius="1" Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Border.Background><SolidColorBrush Color="#FF9F43"/></Border.Background>
                                </Border>
                                <TextBlock Text="Sorties" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                        <lvc:CartesianChart Grid.Row="1" Series="{Binding MouvementsSeries}" LegendLocation="None">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding MouvementsLabels}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11">
                                    <lvc:Axis.Separator><lvc:Separator StrokeThickness="0"/></lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Foreground="{DynamicResource TextSecondaryColor}" FontSize="10" MinValue="0">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Stroke="{DynamicResource BorderSubtleColor}" StrokeDashArray="4 2"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </Border>

                <!-- Historique récent -->
                <Border Grid.Column="2" Background="{DynamicResource CardBgColor}" CornerRadius="16"
                        BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="0,0,0,1" Padding="20,16">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="History" Width="20" Height="20" Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Derniers mouvements" Foreground="{DynamicResource TextPrimaryColor}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                            <ItemsControl ItemsSource="{Binding MouvementsRecents}" Margin="12,8,12,12">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource CardBgDarkerColor}" CornerRadius="10" Margin="0,3" Padding="12,8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource CardHoverColor}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="30" Height="30" CornerRadius="8" Margin="0,0,10,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background"><Setter.Value><SolidColorBrush Color="#45E3B8" Opacity="0.15"/></Setter.Value></Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEntree}" Value="False">
                                                                    <Setter Property="Background"><Setter.Value><SolidColorBrush Color="#FF9F43" Opacity="0.15"/></Setter.Value></Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <materialDesign:PackIcon Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <materialDesign:PackIcon.Style>
                                                            <Style TargetType="materialDesign:PackIcon">
                                                                <Setter Property="Kind"       Value="ArrowDownBold"/>
                                                                <Setter Property="Foreground" Value="#45E3B8"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEntree}" Value="False">
                                                                        <Setter Property="Kind"       Value="ArrowUpBold"/>
                                                                        <Setter Property="Foreground" Value="#FF9F43"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </materialDesign:PackIcon.Style>
                                                    </materialDesign:PackIcon>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Produit}" Foreground="{DynamicResource TextPrimaryColor}" FontWeight="SemiBold" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Motif}"   Foreground="{DynamicResource TextSecondaryColor}" FontSize="9"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <TextBlock FontWeight="Bold" FontSize="12" HorizontalAlignment="Right">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#45E3B8"/>
                                                                <Setter Property="Text"       Value="{Binding Quantite, StringFormat='+{0}'}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEntree}" Value="False">
                                                                        <Setter Property="Foreground" Value="#FF9F43"/>
                                                                        <Setter Property="Text"       Value="{Binding Quantite, StringFormat='-{0}'}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Date, StringFormat='{}{0:dd/MM HH:mm}'}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

        </Grid>
    </ScrollViewer>
</UserControl>
