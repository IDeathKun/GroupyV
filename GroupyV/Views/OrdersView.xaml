<UserControl x:Class="GroupyV.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:GroupyV.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>

        <!-- Style pour les badges de statut -->
        <Style x:Key="BadgeExpédié" TargetType="Border">
            <Setter Property="Background" Value="#1A4D2E"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,5"/>
        </Style>
        <Style x:Key="BadgeEnAttente" TargetType="Border">
            <Setter Property="Background" Value="#3E2C1F"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Gestion des Commandes" Foreground="{DynamicResource TextPrimaryColor}" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Suivez et gérez les expéditions pour chaque client." Foreground="{DynamicResource TextSecondaryColor}" FontSize="13" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- KPI RÉSUMÉ -->
        <UniformGrid Grid.Row="1" Columns="3" Margin="0,10,0,25">
            <!-- Total clients -->
            <Border Background="{DynamicResource CardBgColor}" CornerRadius="14" Padding="20,14" Margin="0,0,10,0" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Border Width="42" Height="42" CornerRadius="12" Background="{DynamicResource BorderSubtleColor}" Margin="0,0,14,0">
                        <materialDesign:PackIcon Kind="AccountGroupOutline" Width="22" Height="22" Foreground="#6C5DD3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding TotalClients}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Clients" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- En attente -->
            <Border Background="{DynamicResource CardBgColor}" CornerRadius="14" Padding="20,14" Margin="5,0" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Border Width="42" Height="42" CornerRadius="12" Background="#3E2C1F" Margin="0,0,14,0">
                        <materialDesign:PackIcon Kind="ClockOutline" Width="22" Height="22" Foreground="#FF9100" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding TotalEnAttente}" Foreground="#FF9100" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="En attente" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Expédiées -->
            <Border Background="{DynamicResource CardBgColor}" CornerRadius="14" Padding="20,14" Margin="10,0,0,0" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Border Width="42" Height="42" CornerRadius="12" Background="#1A4D2E" Margin="0,0,14,0">
                        <materialDesign:PackIcon Kind="TruckCheckOutline" Width="22" Height="22" Foreground="#00E676" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding TotalExpediees}" Foreground="#00E676" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Expédiées" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- LISTE CLIENTS -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden">
            <ItemsControl ItemsSource="{Binding ClientGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Background="{DynamicResource CardBgColor}" UniformCornerRadius="16" Margin="0,0,0,16" materialDesign:ElevationAssist.Elevation="Dp2">
                            <StackPanel>

                                <!-- EN-TÊTE CLIENT -->
                                <Grid Margin="22,18,22,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar + Infos -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Border Width="48" Height="48" CornerRadius="24" Margin="0,0,14,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#6C5DD3" Offset="0"/>
                                                    <GradientStop Color="#8F7CEC" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="{Binding Initiales}" Foreground="White" FontSize="16" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding NomComplet}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="16" FontWeight="Bold"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <materialDesign:PackIcon Kind="EmailOutline" Width="13" Foreground="{DynamicResource TextSecondaryColor}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Email}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11" Margin="0,0,12,0"/>
                                                <materialDesign:PackIcon Kind="MapMarkerOutline" Width="13" Foreground="{DynamicResource TextSecondaryColor}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Adresse}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- KPIs + Badge -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <StackPanel Margin="0,0,18,0" HorizontalAlignment="Center">
                                            <TextBlock Text="COMMANDES" Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding NbCommandes}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <Border Width="1" Height="30" Background="{DynamicResource BorderSubtleColor}" Margin="0,0,18,0"/>

                                        <StackPanel Margin="0,0,18,0" HorizontalAlignment="Center">
                                            <TextBlock Text="TOTAL" Foreground="{DynamicResource TextSecondaryColor}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding TotalCA, StringFormat={}{0:N2} €}" Foreground="#45E3B8" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <Border Width="1" Height="30" Background="{DynamicResource BorderSubtleColor}" Margin="0,0,18,0"/>

                                        <!-- Badge statut dynamique -->
                                        <Border CornerRadius="8" Padding="14,6" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#3E2C1F"/>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center">
                                                    <materialDesign:PackIcon.Style>
                                                        <Style TargetType="materialDesign:PackIcon">
                                                            <Setter Property="Kind" Value="ClockOutline"/>
                                                            <Setter Property="Foreground" Value="#FF9100"/>
                                                        </Style>
                                                    </materialDesign:PackIcon.Style>
                                                </materialDesign:PackIcon>
                                                <TextBlock Text="{Binding StatutGlobal}" FontWeight="Bold" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#FF9100"/>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <!-- LISTE DES COMMANDES DU CLIENT -->
                                <Border Background="{DynamicResource CardBgDarkerColor}" CornerRadius="0,0,16,16" Padding="14,10,14,14"
                                        BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="0,1,0,0">
                                    <ItemsControl ItemsSource="{Binding Preventes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource CardHoverColor}" CornerRadius="12" Margin="0,4" Padding="14,10">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource CardHoverColor}"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Image produit -->
                                                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10" Margin="0,0,12,0" Background="{DynamicResource CardBgDarkerColor}" BorderBrush="{DynamicResource BorderSubtleColor}" BorderThickness="1">
                                                            <Grid ClipToBounds="True">
                                                                <materialDesign:PackIcon Kind="PackageVariantClosed" Foreground="{DynamicResource InputBorderColor}" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                <Image Source="{Binding Prevente.Produit.Image, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- Info produit -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Prevente.Produit.NomProduit}" Foreground="{DynamicResource TextPrimaryColor}" FontSize="13" FontWeight="SemiBold"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                <TextBlock Text="{Binding Prevente.IdPrevente, StringFormat='#{0}'}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                                                                <TextBlock Text=" • " Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                                                                <TextBlock Text="{Binding Prevente.Statut}" Foreground="#FFB74D" FontSize="10"/>
                                                                <TextBlock Text=" • " Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                                                                <TextBlock Text="{Binding Prevente.DateLimite, StringFormat='Limite : {0:dd/MM/yy}'}" Foreground="{DynamicResource TextSecondaryColor}" FontSize="10"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <!-- Prix -->
                                                        <TextBlock Grid.Column="2" Text="{Binding Prevente.PrixPrevente, StringFormat={}{0:N2} €}" 
                                                                   Foreground="#45E3B8" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,0,14,0"/>

                                                        <!-- Badge statut expédition -->
                                                        <Border Grid.Column="3" CornerRadius="6" Padding="8,3" VerticalAlignment="Center" Margin="0,0,10,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#3E2C1F"/>
                                                                </Style>
                                                            </Border.Style>
                                                            <StackPanel Orientation="Horizontal">
                                                                <materialDesign:PackIcon Width="12" Height="12" Margin="0,0,4,0" VerticalAlignment="Center">
                                                                    <materialDesign:PackIcon.Style>
                                                                        <Style TargetType="materialDesign:PackIcon">
                                                                            <Setter Property="Kind" Value="ClockOutline"/>
                                                                            <Setter Property="Foreground" Value="#FF9100"/>
                                                                        </Style>
                                                                    </materialDesign:PackIcon.Style>
                                                                </materialDesign:PackIcon>
                                                                <TextBlock Text="{Binding StatutText}" FontSize="10" FontWeight="Bold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="#FF9100"/>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- Bouton gérer -->
                                                        <Button Grid.Column="4" 
                                                                Command="{Binding DataContext.ManageOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding Prevente.IdPrevente}" 
                                                                Height="32" materialDesign:ButtonAssist.CornerRadius="8"
                                                                Padding="14,0" Cursor="Hand">
                                                            <Button.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Color="#6C5DD3" Offset="0"/>
                                                                    <GradientStop Color="#8F7CEC" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Button.Background>
                                                            <StackPanel Orientation="Horizontal">
                                                                <materialDesign:PackIcon Kind="ArrowRight" Width="16" Height="16" Margin="0,0,4,0"/>
                                                                <TextBlock Text="GÉRER" FontWeight="Bold" FontSize="11"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </StackPanel>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>